{
  "name": "ford-avon-backend",
  "private": true,
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test:supabase": "npm run build && node dist/scripts/testSupabase.js",
    "import:cartera:test": "npm run build && node dist/scripts/importCartera.js --limit=100 --test",
    "import:cartera": "npm run build && node dist/scripts/importCartera.js",
    "clear:cartera": "npm run build && node dist/scripts/clearCartera.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.18",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
