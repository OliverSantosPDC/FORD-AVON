# Configuración del backend FORD-AVON
# Copia este archivo como ".env" y completa los valores reales.
# NUNCA subas el archivo .env con credenciales reales a GitHub.

# Puerto del servidor Express
PORT=4000

# Fuente de datos del dashboard: "supabase" (por defecto) o "excel" (fallback)
DATA_SOURCE=supabase

# --- Credenciales de Supabase ---
# URL del proyecto, p. ej. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Service Role Key (uso exclusivo del backend, NUNCA en el frontend)
SUPABASE_SERVICE_ROLE_KEY=

# Nombre de la tabla de cartera (opcional, por defecto "cartera")
SUPABASE_CARTERA_TABLE=cartera
